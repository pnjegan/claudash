# Claudash — files intentionally kept out of source control

# ── Runtime data (regenerated from JSONL on every scan) ──
data/usage.db
data/usage.db-wal
data/usage.db-shm
data/*.csv

# ── Local tool variants ──
tools/mac-sync-local.py
tools/oauth_sync-local.py

# ── Python build artifacts ──
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Environment / secrets ──
.env
.env.local
*.pem

# ── OS junk ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ──
*.log

# ── Editor state ──
.vscode/
.idea/
*.swp
*.swo

# ── Packaging sandbox (if someone ever ships a PyPI package) ──
claudash/
dist/
build/
*.egg-info/
data/usage.db
data/usage.db-wal
data/usage.db-shm
__pycache__/
*.pyc
FOUNDING_DOC.md
END_USER_REVIEW.md
REPORT.md
usage_export.csv

# ── Local agent / CDC tracking (per-machine only) ──
.claude/
.dev-cdc/
.npmrc
